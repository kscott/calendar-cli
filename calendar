#!/bin/bash
# calendar — wrapper script for calendar-bin
#
# Source lives at:  ~/dev/calendar-cli/
# Binary lives at:  ~/bin/calendar-bin
# Symlink at:       ~/bin/calendar -> ~/dev/calendar-cli/calendar
#
# To set up on a new machine:
#   ~/dev/calendar-cli/calendar setup
#
# To run tests:
#   ~/dev/calendar-cli/calendar test

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
BINARY="$HOME/bin/calendar-bin"
SYMLINK="$HOME/bin/calendar"

if [[ "$1" == "setup" ]]; then
  echo "Building $SCRIPT_DIR..."
  swift build -c release --package-path "$SCRIPT_DIR" 2>&1 || { echo "Build failed."; exit 1; }
  echo "Build OK."

  cp "$SCRIPT_DIR/.build/release/calendar-bin" "$BINARY" || { echo "Copy failed."; exit 1; }
  echo "Installed binary to $BINARY."

  echo "Creating symlink $SYMLINK -> $SCRIPT_DIR/calendar..."
  ln -sf "$SCRIPT_DIR/calendar" "$SYMLINK" || { echo "Symlink failed."; exit 1; }
  echo "Done. Run 'calendar' to get started."
  exit 0
fi

if [[ "$1" == "test" ]]; then
  swift build --package-path "$SCRIPT_DIR" 2>&1 || { echo "Build failed."; exit 1; }
  BIN_PATH="$(swift build --package-path "$SCRIPT_DIR" --show-bin-path 2>/dev/null)"
  "$BIN_PATH/calendar-tests"
  exit $?
fi

exec "$BINARY" "$@"
